---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Welcome to my blog</h1>
			<p>
				This is a personal blog built with <a href="https://astro.build/">Astro</a> and MDX.
				I share thoughts, projects, and technical explorations here.
			</p>
			<p>
				You can explore my <a href="/blog">latest blog posts</a> or check out some of my
				<a href="#projects">projects</a> below.
			</p>
			<section id="projects">
				<h2>Projects</h2>
				<p>
					<a href="https://github.com/Yanagi-0912/weblesson_maindesign">大二網頁程式設計專題</a>
				</p>
				<p>
					<a href="https://github.com/Yogurtheyork/JAVA_final">大二JAVA程式設計專題</a>
				</p>
				<p>
					<a href="https://github.com/Yanagi-0912/javaOthello">黑白棋遊戲(JAVA桌面應用程式+ai對戰)</a>
				</p>
				<p>
					<a href="https://github.com/Yanagi-0912/SEProject2025Frontend">大三軟體工程專題(前端)</a>
					<a href="https://github.com/Yanagi-0912/SEProject2025Backend">大三軟體工程專題(後端)</a>
				</p>
				<p>
					<a href="https://github.com/Yanagi-0912/DBProject2025">大三資料庫專題</a>
				</p>
				<p>
					<a href="https://github.com/Yanagi-0912/CARE">CARE (Clinical Assistance & Resource Engine):一個以高齡友善設計、資料準確性保障與 AI 科技整合為核心目標的適地性健康醫療資訊 AI 助手。</a>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
